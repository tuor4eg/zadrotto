DATABASE_URL=postgres://user:password@localhost:5432/zadrotto
SITE_URL=https://zadrotto.guskov.dev

ADMIN_LOGIN=admin
ADMIN_PASSWORD=change-me
ADMIN_SESSION_SECRET=change-this-to-a-long-random-secret
COVER_CANDIDATE_SECRET=change-this-to-a-third-long-random-secret
COVER_PROVIDER_CREDENTIALS_KEY=change-this-to-a-long-random-master-key
AUTHOR_REGISTRATION_ENABLED=false
# Deprecated transition fallback. Configure the profile in /admin/settings/authors.
AUTHOR_REGISTRATION_ACCESS_PROFILE_CODE=
EMAIL_OUTBOX_ENCRYPTION_KEY=change-this-to-a-long-random-email-outbox-key
EMAIL_PROVIDER_CREDENTIALS_KEY=change-this-to-a-separate-long-random-email-provider-key
AUTH_EMAIL_WORKER_SECRET=change-this-to-a-long-random-worker-secret
REDIS_URL=redis://127.0.0.1:6379
SECURE_COOKIES=false

S3_ENDPOINT=http://127.0.0.1:9000
S3_REGION=us-east-1
S3_BUCKET=zadrotto
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_FORCE_PATH_STYLE=true
S3_PUBLIC_BASE_URL=http://127.0.0.1:9000/zadrotto
